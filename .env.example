# .env.example
# Since we deploy with Cloudflare Pages, these env vars should be written in Cloudflare settings
# Google OAuth ID, SECRET 要從 Google Cloud Console 取得
NUXT_SESSION_PASSWORD=
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=
NUXT_OAUTH_GOOGLE_REDIRECT_URL= # https://yourdomain.com/api/auth/google
NUXT_GITHUB_TOKEN= # data repo 用的 webhook token