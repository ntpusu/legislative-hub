# .env.example
# Since we deploy with Cloudflare Pages, these env vars should be written in Cloudflare settings
NUXT_SESSION_PASSWORD=
# ===== Google OAuth =====
# Google OAuth ID, SECRET 要從 Google Cloud Console 取得。
# 本專案目前之部署版，係以三峽議會帳號使用 Google Cloud Console.
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=
NUXT_OAUTH_GOOGLE_REDIRECT_URL= # https://yourdomain.com/api/auth/google
# ===== GitHub Token =====
# 這是讓使用者觸發 legislative-data repo 中，GitHub repository_dispatch API 用的 token
# 需要由 ntpusu 組織管理員生成（個人 GitHub 右上角大頭貼 -> Settings -> 
# 左側最下方 Developer settings -> Personal access tokens ），
# Repository access only select `legislative-data`, Repository permissions 找到 Contents，
# 設定為 Read and write （觸發 repository_dispatch 需要）。
NUXT_GITHUB_TOKEN= 
